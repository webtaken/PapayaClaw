# Database Credentials
DATABASE_URL=

# Better Auth Configuration
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Hetzner Cloud (VPS Provisioning)
HETZNER_API_TOKEN=
HETZNER_SERVER_LIMIT=5  # Account cap — provisioning rejects when this many instances exist

# Clouflare Configurations
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# Polar Payments
POLAR_ACCESS_TOKEN= # Optional (don't setup if you are developing)
POLAR_WEBHOOK_SECRET= # Optional (don't setup if you're developing)
POLAR_SERVER=sandbox  # "sandbox" for testing, "production" for live
NEXT_PUBLIC_POLAR_BASIC_PRODUCT_ID=   # Needed for checkout URLs only
NEXT_PUBLIC_POLAR_PRO_PRODUCT_ID=     # Needed for checkout URLs only
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pending instance config encryption (AES-256-GCM key, base64 32 bytes).
# Generate with: openssl rand -base64 32
INSTANCE_CONFIG_ENC_KEY=
